# ── ngrok (for public deployment via start-ngrok.sh) ─────────────────────────
# Get your auth token at: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# Optional: static ngrok domain (from https://dashboard.ngrok.com/domains)
# Leave empty to use a random ephemeral URL
NGROK_DOMAIN=

# ── Frontend ──────────────────────────────────────────────────────────────────
# Set to your backend URL (default: http://localhost:5000)
NEXT_PUBLIC_API_URL=http://localhost:5000
