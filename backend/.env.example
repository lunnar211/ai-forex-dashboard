# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (REQUIRED)
DATABASE_URL=postgresql://user:password@localhost:5432/ai_forex

# ─── Authentication ───────────────────────────────────────────────────────────
# Secret used to sign JWT tokens — use a long random string (REQUIRED)
JWT_SECRET=replace_with_a_long_random_secret

# ─── AI Providers ─────────────────────────────────────────────────────────────
# At least ONE of the following AI provider keys is required.
# Obtain keys from the respective provider dashboards.
GROQ_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ─── Forex Data ───────────────────────────────────────────────────────────────
# Twelve Data API key — without this the app falls back to mock data (optional)
# https://twelvedata.com/
TWELVE_DATA_API_KEY=

# ─── Redis ────────────────────────────────────────────────────────────────────
# Redis connection URL — caching is disabled gracefully if not set (optional)
REDIS_URL=redis://localhost:6379

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
# Restrict CORS to your frontend URL in production
CORS_ORIGIN=http://localhost:3000
