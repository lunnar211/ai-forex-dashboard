# =============================================================================
# AI Forex Dashboard – Frontend Environment Variables
# =============================================================================
# IMPORTANT: Never commit this file with real values filled in.
#            Copy it to `.env.local` locally and fill in your values.
#            On Render.com, this is set automatically via the render.yaml
#            blueprint (NEXT_PUBLIC_API_URL is injected from the backend URL).
# =============================================================================

# URL of the backend API server.
# In production replace with your deployed backend URL, e.g.:
#   https://ai-forex-backend.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:5000
