# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Set to your frontend origin in production, e.g. https://yourapp.vercel.app
CORS_ORIGIN=http://localhost:3000

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
# Required. Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_forex

# ─── Authentication ───────────────────────────────────────────────────────────
# Required. Use a long, random string (e.g. openssl rand -hex 64)
JWT_SECRET=change_me_to_a_long_random_secret

# ─── Redis (optional — used for caching and rate limiting) ────────────────────
REDIS_URL=redis://localhost:6379

# ─── Forex Data (optional — falls back to mock data if not set) ───────────────
# Get your free key at https://twelvedata.com
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# ─── AI Providers (at least one required) ────────────────────────────────────
# Get your key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Get your key at https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# Get your key at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
