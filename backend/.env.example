# ── Critical (app will not start without these) ───────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/forex_db
JWT_SECRET=replace-with-a-long-random-secret

# ── Admin credentials (owner-only access to /admin panel) ────────────────────
ADMIN_EMAIL=dipeshkarki6612@gmail.com
ADMIN_PASSWORD=your-secure-admin-password

# ── AI Providers (at least one must be set) ───────────────────────────────────
GROQ_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────
# Real-time forex data (falls back to mock data when not set)
TWELVE_DATA_API_KEY=

# Redis cache (app runs fine without it, just slower)
REDIS_URL=redis://localhost:6379

# Allowed CORS origin(s) – set to your frontend URL in production
CORS_ORIGIN=http://localhost:3000

# Server port (default: 5000)
PORT=5000

NODE_ENV=development
