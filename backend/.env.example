# =============================================================================
# AI Forex Dashboard – Backend Environment Variables
# =============================================================================
# IMPORTANT: Never commit this file with real values filled in.
#            Copy it to `.env` locally and fill in your own secrets.
#            On Render.com, set these values in the dashboard under
#            "Environment Variables" for the backend service.
# =============================================================================

# ── Critical (app will not start without these) ───────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/forex_db
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# ── Admin credentials (REQUIRED for the /admin panel to work) ────────────────
# On startup, the backend automatically creates (or updates) an admin user in
# the database using these values.  Changing them and restarting the server
# will sync the change.
#
# If a user with ADMIN_EMAIL already exists but has no admin privileges,
# the login endpoint will auto-promote them when these credentials match.
#
# On Render: set ADMIN_EMAIL and ADMIN_PASSWORD in the dashboard under
#   "Environment Variables" for the backend service, then redeploy.
# Locally:   copy this file to .env and fill in your values.
ADMIN_EMAIL=your-admin-email@example.com
ADMIN_PASSWORD=your-secure-admin-password

# ── AI Providers (at least one must be set) ───────────────────────────────────
# Get your keys from the respective provider dashboards.
# The app will use whichever keys are present, falling back through providers.
GROQ_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# ── Market Data ───────────────────────────────────────────────────────────────
# Real-time forex data via Twelve Data (https://twelvedata.com).
# Falls back to mock data when not set.
TWELVE_DATA_API_KEY=

# ── Infrastructure (optional) ─────────────────────────────────────────────────
# Redis cache — app runs fine without it, just slower
REDIS_URL=redis://localhost:6379

# Allowed CORS origin(s) – set to your frontend URL in production
CORS_ORIGIN=http://localhost:3000

# Server port (default: 5000)
PORT=5000

NODE_ENV=development
