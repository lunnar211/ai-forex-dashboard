# ── Root .env for Docker Compose ─────────────────────────────────────────────
# Copy this file to .env and fill in the values before running docker compose.
#
#   cp .env.example .env
#   docker compose up --build -d

# ── Critical ──────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret

# ── AI Providers (at least one must be set) ───────────────────────────────────
GROQ_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────
# Real-time forex data (falls back to mock data when not set)
TWELVE_DATA_API_KEY=

# Allowed CORS origin – set to your frontend URL in production
CORS_ORIGIN=http://localhost:3000

# Frontend → Backend URL (used by the Next.js build)
NEXT_PUBLIC_API_URL=http://localhost:5000
