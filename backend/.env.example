# ── Critical (app will not start without these) ───────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/forex_db
JWT_SECRET=replace-with-a-long-random-secret

# ── Admin credentials (REQUIRED for the /admin panel to work) ────────────────
# These are kept secret — never commit actual values to source control.
# On startup, the backend automatically creates (or updates) an admin user in
# the database using these values, so changing them here and restarting the
# server will sync the change.
#
# On Render: set ADMIN_EMAIL and ADMIN_PASSWORD in the dashboard under
#   "Environment Variables" for the backend service, then redeploy.
# Locally:   copy this file to .env and fill in your values.
ADMIN_EMAIL=your-admin-email@example.com
ADMIN_PASSWORD=your-secure-admin-password

# ── AI Providers (at least one must be set) ───────────────────────────────────
GROQ_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────
# Real-time forex data (falls back to mock data when not set)
TWELVE_DATA_API_KEY=

# Redis cache (app runs fine without it, just slower)
REDIS_URL=redis://localhost:6379

# Allowed CORS origin(s) – set to your frontend URL in production
CORS_ORIGIN=http://localhost:3000

# Server port (default: 5000)
PORT=5000

NODE_ENV=development
