# =============================================================================
# AI Forex Dashboard – Root Environment Variables (Docker Compose)
# =============================================================================
# IMPORTANT: Never commit this file with real values filled in.
#            Copy it to `.env` in this directory and fill in your own secrets.
#
#   cp .env.example .env
#   # then edit .env with your values
#   docker compose up --build -d
#
# On Render.com:
#   Set these values in the Render dashboard under "Environment Variables"
#   for the backend service (https://dashboard.render.com).
#   The DATABASE_URL, REDIS_URL, JWT_SECRET, CORS_ORIGIN, and
#   NEXT_PUBLIC_API_URL are auto-linked by the render.yaml Blueprint.
# =============================================================================

# ── Admin credentials ─────────────────────────────────────────────────────────
# The backend seeds an admin account on startup using these values.
# Change them (and restart) to update the admin password.
ADMIN_EMAIL=your-admin-email@example.com
ADMIN_PASSWORD=your-secure-admin-password

# ── AI Providers (at least one must be set) ───────────────────────────────────
# Groq  – https://console.groq.com
GROQ_API_KEY=

# OpenAI – https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini – https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# OpenRouter – https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# ── Market Data ───────────────────────────────────────────────────────────────
# Twelve Data – https://twelvedata.com (free tier: 800 calls/day)
# Falls back to realistic mock data when not set.
TWELVE_DATA_API_KEY=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Used only by Docker Compose (auto-generated on Render Blueprint deployments).
# Must be a long random string (32+ characters).
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# ── Frontend URL (Docker Compose only) ───────────────────────────────────────
# Auto-linked on Render. For Docker Compose, set to http://localhost:5000.
NEXT_PUBLIC_API_URL=http://localhost:5000

# ── CORS (Docker Compose only) ────────────────────────────────────────────────
# Auto-linked on Render. For Docker Compose, set to http://localhost:3000.
CORS_ORIGIN=http://localhost:3000
